<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lateral Inhibition — Hermann Grid</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: system-ui, sans-serif; background: #ffffff; color: #1a1a1a; padding: 2rem; max-width: 720px; margin: 0 auto; }
  h2 { font-size: 18px; font-weight: 500; margin-bottom: 0.4rem; }
  p.sub { font-size: 14px; color: #555; margin-bottom: 1.5rem; line-height: 1.6; }
  .btn-row { display: flex; gap: 8px; margin-bottom: 1rem; }
  .loc-btn { font-size: 13px; padding: 6px 14px; border: 1px solid #ccc; border-radius: 8px; background: #fff; color: #555; cursor: pointer; transition: all .2s; }
  .loc-btn.active { background: #f3f3f3; color: #111; border-color: #888; font-weight: 500; }
  .panel { display: flex; gap: 24px; flex-wrap: wrap; align-items: flex-start; }
  .stat-section { flex: 1; min-width: 180px; display: flex; flex-direction: column; gap: 16px; justify-content: center; padding-top: 8px; }
  .label-sm { font-size: 12px; color: #666; margin-bottom: 2px; }
  .stat-val { font-size: 22px; font-weight: 500; transition: color 0.4s; }
  .inhibition-bar-bg { height: 10px; border-radius: 5px; background: #e5e5e5; overflow: hidden; margin-top: 4px; }
  .inhibition-bar { height: 10px; border-radius: 5px; transition: width 0.5s ease, background 0.5s ease; }
  .axis-labels { display: flex; justify-content: space-between; font-size: 11px; color: #999; margin-top: 3px; }
  .brightness-label { font-size: 12px; color: #666; margin-bottom: 6px; }
  .brightness-box { width: 52px; height: 52px; border-radius: 8px; border: 1px solid #ddd; transition: background 0.5s; }
  .verdict { font-size: 13px; margin-top: 12px; padding: 10px 14px; border-radius: 8px; background: #f5f5f5; color: #444; line-height: 1.6; transition: all 0.4s; }

  @media (prefers-color-scheme: dark) {
    body { background: #1a1a1a; color: #e5e5e5; }
    .loc-btn { background: #2a2a2a; border-color: #444; color: #aaa; }
    .loc-btn.active { background: #333; color: #eee; border-color: #888; }
    .inhibition-bar-bg { background: #333; }
    .verdict { background: #252525; color: #bbb; }
    .label-sm, .axis-labels, .brightness-label { color: #888; }
    .brightness-box { border-color: #444; }
  }
</style>
</head>
<body>

<h2>Lateral Inhibition — Hermann Grid</h2>
<p class="sub">The gray smudges at intersections arise from differential surround inhibition in ON-center retinal ganglion cells. Toggle between the two positions to see the mechanism.</p>

<div class="btn-row">
  <button class="loc-btn active" id="btn-corridor" onclick="setMode('corridor')">Along a corridor</button>
  <button class="loc-btn" id="btn-intersection" onclick="setMode('intersection')">At an intersection</button>
</div>

<div class="panel">
  <div style="flex: 0 0 auto;">
    <svg id="grid-svg" width="260" height="260" viewBox="0 0 260 260" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <marker id="arr2" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse">
          <path d="M2 1L8 5L2 9" fill="none" stroke="context-stroke" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </marker>
      </defs>

      <!-- White background (corridors) -->
      <rect x="0" y="0" width="260" height="260" fill="#ffffff"/>

      <!-- Black squares: 3x3 grid, 72px squares, 22px corridors -->
      <rect x="0"   y="0"   width="72" height="72" fill="#1a1a1a"/>
      <rect x="94"  y="0"   width="72" height="72" fill="#1a1a1a"/>
      <rect x="188" y="0"   width="72" height="72" fill="#1a1a1a"/>
      <rect x="0"   y="94"  width="72" height="72" fill="#1a1a1a"/>
      <rect x="94"  y="94"  width="72" height="72" fill="#1a1a1a"/>
      <rect x="188" y="94"  width="72" height="72" fill="#1a1a1a"/>
      <rect x="0"   y="188" width="72" height="72" fill="#1a1a1a"/>
      <rect x="94"  y="188" width="72" height="72" fill="#1a1a1a"/>
      <rect x="188" y="188" width="72" height="72" fill="#1a1a1a"/>

      <!-- CORRIDOR cell: center at (130, 83) — midpoint of top horizontal corridor -->
      <g id="cell-corridor">
        <circle cx="130" cy="83" r="30" fill="none" stroke="#f59e0b" stroke-width="2" stroke-dasharray="4 3" opacity="0.9"/>
        <circle cx="130" cy="83" r="10" fill="none" stroke="#f59e0b" stroke-width="2" opacity="0.9"/>
        <!-- left white corridor segment in surround -->
        <rect x="72" y="68" width="48" height="30" fill="#f59e0b" opacity="0.22" rx="2"/>
        <!-- right white corridor segment in surround -->
        <rect x="140" y="68" width="48" height="30" fill="#f59e0b" opacity="0.22" rx="2"/>
        <circle cx="130" cy="83" r="3" fill="#f59e0b"/>
      </g>

      <!-- INTERSECTION cell: center at (83, 83) -->
      <g id="cell-intersection" opacity="0">
        <circle cx="83" cy="83" r="30" fill="none" stroke="#ef4444" stroke-width="2" stroke-dasharray="4 3" opacity="0.9"/>
        <circle cx="83" cy="83" r="10" fill="none" stroke="#ef4444" stroke-width="2" opacity="0.9"/>
        <!-- four white surround segments -->
        <rect x="68" y="53"  width="30" height="20" fill="#ef4444" opacity="0.22" rx="2"/>
        <rect x="68" y="90"  width="30" height="20" fill="#ef4444" opacity="0.22" rx="2"/>
        <rect x="53" y="68"  width="20" height="30" fill="#ef4444" opacity="0.22" rx="2"/>
        <rect x="90" y="68"  width="20" height="30" fill="#ef4444" opacity="0.22" rx="2"/>
        <circle cx="83" cy="83" r="3" fill="#ef4444"/>
      </g>
    </svg>
  </div>

  <div class="stat-section">
    <div>
      <div class="label-sm">White light in surround</div>
      <div class="stat-val" id="surround-count" style="color: #f59e0b;">2 segments</div>
    </div>

    <div>
      <div class="label-sm">Lateral inhibition</div>
      <div class="inhibition-bar-bg">
        <div class="inhibition-bar" id="inhibition-bar" style="width: 40%; background: #f59e0b;"></div>
      </div>
      <div class="axis-labels"><span>low</span><span>high</span></div>
    </div>

    <div>
      <div class="label-sm">Cell output (firing rate)</div>
      <div class="inhibition-bar-bg">
        <div class="inhibition-bar" id="firing-bar" style="width: 72%; background: #f59e0b;"></div>
      </div>
      <div class="axis-labels"><span>dim</span><span>bright</span></div>
    </div>

    <div>
      <div class="brightness-label">Perceived brightness</div>
      <div class="brightness-box" id="brightness-box" style="background: #f0f0f0;"></div>
    </div>
  </div>
</div>

<div class="verdict" id="verdict">
  <strong>Corridor cell:</strong> only 2 white corridor arms enter the surround. Moderate inhibition → cell fires well → white is perceived as white.
</div>

<script>
function setMode(mode) {
  const isCorridor = mode === 'corridor';
  document.getElementById('btn-corridor').classList.toggle('active', isCorridor);
  document.getElementById('btn-intersection').classList.toggle('active', !isCorridor);
  document.getElementById('cell-corridor').style.opacity = isCorridor ? '1' : '0';
  document.getElementById('cell-intersection').style.opacity = isCorridor ? '0' : '1';

  const color = isCorridor ? '#f59e0b' : '#ef4444';

  document.getElementById('surround-count').textContent = isCorridor ? '2 segments' : '4 segments';
  document.getElementById('surround-count').style.color = color;

  document.getElementById('inhibition-bar').style.width = isCorridor ? '38%' : '85%';
  document.getElementById('inhibition-bar').style.background = color;

  document.getElementById('firing-bar').style.width = isCorridor ? '74%' : '22%';
  document.getElementById('firing-bar').style.background = color;

  document.getElementById('brightness-box').style.background = isCorridor ? '#f2f2f2' : '#bebebe';

  document.getElementById('verdict').innerHTML = isCorridor
    ? '<strong>Corridor cell:</strong> only 2 white arms enter the surround. Moderate inhibition → cell fires well → the corridor looks white, as expected.'
    : '<strong>Intersection cell:</strong> 4 white arms flood the surround from all directions. Maximum inhibition → cell barely fires → the brain reads this as <em>gray</em>, producing the smudge — even though the luminance is identical.';
}
</script>

</body>
</html>
